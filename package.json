{
  "name": "boxstarter.org",
  "packageManager": "yarn@4.13.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chocolatey-community/boxstarter.org.git"
  },
  "author": "chocolatey",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/chocolatey-community/boxstarter.org/issues"
  },
  "homepage": "https://github.com/chocolatey-community/boxstarter.org#readme",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "audit": "yarn npm audit --all --recursive --no-deprecations",
    "audit-direct": "yarn npm audit --all --no-deprecations",
    "audit-resolve": "powershell -NoProfile -File node_modules/@chocolatey-software/build-tools/build/Resolve-YarnAudit.ps1",
    "build-copy-theme": "npx tsx node_modules/@chocolatey-software/build-tools/build/copy-theme.ts boxstarter",
    "build-purge-css": "npx tsx node_modules/@chocolatey-software/build-tools/build/purge-css.ts boxstarter",
    "choco-theme": "yarn build-copy-theme && yarn build-purge-css",
    "link-github": "npx tsx node_modules/@chocolatey-software/build-tools/build/link-github.ts",
    "link-local": "npx tsx node_modules/@chocolatey-software/build-tools/build/link-local.ts"
  },
  "devDependencies": {
    "@chocolatey-software/assets": "2.0.0",
    "@chocolatey-software/build-tools": "2.9.2"
  },
  "dependencies": {
    "@chocolatey-software/boxstarter": "2.9.0"
  }
}
